.DS_Store
node_modules/

# external-locations/* are symlinks into the shared library and canonical kit.
# Git tracks the links themselves (not their contents); nothing to ignore for the
# payload, but never commit a materialized copy if a link is ever replaced by a dir.

# The Asset Explorer's thumbnail bake is a LOCAL cache (no published Explorer view) —
# build-asset-registry.mjs regenerates it; machines without a bake fall back to glyphs.
previews/thumbs/

# Local browser QA captures (Playwright snapshots, screenshots, traces).
output/playwright/

# Image-gen handoff working areas (same rationale as thumbs): candidates + style-anchor
# copies are ephemeral by design — only the reviewed winner leaves staging, filed to the
# lore-brain vault by the Claude side. The rolling contract generation/BATCH.md IS tracked.
generation/staging/
generation/refs/

# Codex batch drops (same rationale again). Batches land here as multi-megabyte PNGs —
# the ancient-tech run alone was ~110 MB across five folders — and the reviewed winners
# leave for the shared library, where the full-resolution masters are kept in a dated
# textures/.../_archive/. What stays behind is losing candidates + QA repeats + preview
# sheets: review evidence, cited by the pipeline record, not artifacts worth versioning.
# NOTE: two pre-existing PNGs at output/imagegen/ root were committed before this rule and
# stay tracked — .gitignore does not untrack. `git rm --cached` them if you want them out.
output/imagegen/

# Codex's scratch area for in-flight batches (prompt files, intermediates).
tmp/
